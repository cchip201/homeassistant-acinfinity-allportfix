meta {
  name: Off Mode
  type: http
}

put {
  url: http://www.acinfinityserver.com/api/dev/modeAndSetting?atType=1&devId={{AI_DEVICE_ID}}&port=1&modeAndSettingIdStr=[16,17]&offSpeed=0
  body: none
  auth: inherit
}

params:query {
  atType: 1
  devId: {{AI_DEVICE_ID}}
  port: 1
  modeAndSettingIdStr: [16,17]
  offSpeed: 0
}

headers {
  minversion: 3.5
  User-Agent: {{USER_AGENT}}
}

settings {
  encodeUrl: true
}
