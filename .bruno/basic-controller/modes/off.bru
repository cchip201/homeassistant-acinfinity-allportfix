meta {
  name: Off Mode
  type: http
}

post {
  url: http://www.acinfinityserver.com/api/dev/addDevMode?atType=1&devId={{DEVICE_ID}}&externalPort=1&offSpeed=0
  body: none
  auth: inherit
}

params:query {
  atType: 1
  devId: {{DEVICE_ID}}
  externalPort: 1
  offSpeed: 0
}

body:form-urlencoded {
  atType: 1
  devId: {{DEVICE_ID}}
  offSpead: 0
  port: 1
}

settings {
  encodeUrl: true
}
