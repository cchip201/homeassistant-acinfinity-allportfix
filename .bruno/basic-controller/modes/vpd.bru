meta {
  name: VPD Mode
  type: http
}

post {
  url: http://www.acinfinityserver.com/api/dev/addDevMode?atType=7&devId={{DEVICE_ID}}&externalPort=1&schedStartTime=7200&schedEndtTime=7200
  body: none
  auth: inherit
}

params:query {
  atType: 7
  devId: {{DEVICE_ID}}
  externalPort: 1
  schedStartTime: 7200
  schedEndtTime: 7200
}

body:form-urlencoded {
  atType: 1
  devId: {{DEVICE_ID}}
  offSpead: 0
  port: 1
}

settings {
  encodeUrl: true
}
