meta {
  name: On Mode
  type: http
}

post {
  url: http://www.acinfinityserver.com/api/dev/addDevMode?atType=2&devId={{DEVICE_ID}}&externalPort=1&onSpeed=10
  body: none
  auth: inherit
}

params:query {
  atType: 2
  devId: {{DEVICE_ID}}
  externalPort: 1
  onSpeed: 10
}

body:form-urlencoded {
  atType: 1
  devId: {{DEVICE_ID}}
  offSpead: 0
  port: 1
}

settings {
  encodeUrl: true
}
